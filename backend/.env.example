# ============ DATABASE ============
DATABASE_URL="file:./dev.db"

# ============ SERVER ============
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============ AUTH ============
JWT_SECRET=sua_chave_jwt_super_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=15m
COOKIE_SECRET=sua_chave_cookie_super_secreta

# ============ STRIPE (pagamentos) ============
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============ SPORTS API - The Odds API (odds) ============
# Obtenha em: https://the-odds-api.com (gratuito: 500 req/mês)
ODDS_API_KEY=sua_chave_odds_api

# ============ SPORTS API - API-Football (placar ao vivo, stats, escalações) ============
# Obtenha em: https://rapidapi.com/api-sports/api/api-football (gratuito: 100 req/dia)
API_FOOTBALL_KEY=sua_chave_api_football

# ============ PIX ============
PIX_KEY=seuemail@exemplo.com

# ============ LOGGING ============
LOG_LEVEL=info
